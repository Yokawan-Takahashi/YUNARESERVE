APP_NAME=YUNARI-RESERVE
APP_ENV=production
APP_KEY=                         # php artisan key:generate で生成
APP_DEBUG=false
APP_URL=https://reserve.yoka-wan.co.jp

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yoka202503_yunari   # サーバー管理画面で作成したDB名
DB_USERNAME=yoka202503_yunari   # DBユーザー名
DB_PASSWORD=                    # DBパスワード

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.reserve.yoka-wan.co.jp

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=                      # シン・レンタルサーバーのSMTPホスト（管理画面で確認）
MAIL_PORT=465
MAIL_USERNAME=                  # メールアカウント（例: noreply@reserve.yoka-wan.co.jp）
MAIL_PASSWORD=                  # メールパスワード
MAIL_FROM_ADDRESS="noreply@reserve.yoka-wan.co.jp"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_             # まずテストキー → 確認後 pk_live_ へ
STRIPE_SECRET=sk_test_          # まずテストキー → 確認後 sk_live_ へ
STRIPE_WEBHOOK_SECRET=whsec_    # Stripe > Webhooks > Signing secret

STRIPE_PRICE_ID_STANDARD=price_   # Stripeダッシュボードで作成したPrice ID
STRIPE_PRICE_ID_PREMIUM=price_    # プレミアムプラン（任意）
STRIPE_PRICE_ID=                  # 後方互換（旧設定がある場合）

VITE_APP_NAME="${APP_NAME}"
